# JWT secret - CHANGE THIS in production!
JWT_SECRET=changeme-please-set-a-strong-secret

# Shared secret between edgepanel and nginx-agent.
# If set, the agent rejects requests that do not carry this token.
# Leave empty to disable authentication (not recommended for production).
NGINX_AGENT_TOKEN=changeme-please-set-a-strong-agent-token

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=admin

# Grafana URL (for metrics page link)
GRAFANA_URL=http://localhost:3000
